#!/usr/bin/env bash
set -euo pipefail

# Colors as raw escape bytes (disabled if not a terminal)
if [[ -t 2 ]]; then
  BOLD=$'\033[1m'    DIM=$'\033[2m'
  RED=$'\033[31m'    GREEN=$'\033[32m'
  YELLOW=$'\033[33m' CYAN=$'\033[36m'
  RESET=$'\033[0m'
else
  BOLD='' DIM='' RED='' GREEN='' YELLOW='' CYAN='' RESET=''
fi

log()   { printf '%s\n' "${CYAN}${BOLD}==>${RESET} $*" >&2; }
info()  { printf '%s\n' "    ${DIM}$*${RESET}" >&2; }
err()   { printf '%s\n' "${RED}${BOLD}Error:${RESET} $*" >&2; }
ok()    { printf '%s\n' "${GREEN}${BOLD}==>${RESET} $*" >&2; }
warn()  { printf '%s\n' "${YELLOW}${BOLD}==>${RESET} $*" >&2; }

fmt_time() {
  local s=$1
  if (( s >= 3600 )); then printf '%dh%02dm%02ds' $((s/3600)) $((s%3600/60)) $((s%60))
  elif (( s >= 60 )); then printf '%dm%02ds' $((s/60)) $((s%60))
  else printf '%ds' "$s"
  fi
}

usage() {
  echo "Usage: giton [options] -- <command...>"
  echo "       giton -f <config.json>"
  echo ""
  echo "Run commands on Nix platforms and post GitHub commit statuses."
  echo ""
  echo "Single-step mode:"
  echo "  -s, --system    Nix system string (if omitted, runs on current system)"
  echo "  -n, --name      Check name for GitHub status context (default: command name)"
  echo "  --              Separator before the command to run"
  echo ""
  echo "Multi-step mode:"
  echo "  -f, --file      JSON config file defining steps, systems, and dependencies"
  echo ""
  echo "Common options:"
  echo "  --sha           Pin to a specific commit SHA (skips clean-tree check)"
  echo "  --tui           Enable process-compose TUI (multi-step mode only)"
  echo ""
  echo "Status context: giton/<name> (no --system) or giton/<name>/<system> (with --system)"
  exit 1
}

# Parse arguments
SYSTEM=""
SYSTEM_EXPLICIT=false
NAME=""
CMD=()
SHA_PIN=""
CONFIG_FILE=""
TUI=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s|--system)
      SYSTEM="$2"
      SYSTEM_EXPLICIT=true
      shift 2
      ;;
    -n|--name)
      NAME="$2"
      shift 2
      ;;
    --sha)
      SHA_PIN="$2"
      shift 2
      ;;
    -f|--file)
      CONFIG_FILE="$2"
      shift 2
      ;;
    --tui)
      TUI=true
      shift
      ;;
    --)
      shift
      CMD=("$@")
      break
      ;;
    -h|--help)
      usage
      ;;
    *)
      echo "Error: Unknown option '$1'"
      usage
      ;;
  esac
done

# Ensure we're in a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  err "Not inside a git repository."
  exit 1
fi

# Pin SHA: use --sha if provided, otherwise resolve HEAD
if [[ -n "$SHA_PIN" ]]; then
  SHA="$SHA_PIN"
else
  # Ensure working tree is clean (only when resolving HEAD)
  if ! git diff --quiet || ! git diff --cached --quiet || [[ -n "$(git ls-files --others --exclude-standard)" ]]; then
    err "Working tree is dirty. Commit or stash changes first."
    exit 1
  fi
  SHA=$(git rev-parse HEAD)
fi

# ─── Host configuration ───────────────────────────────────────────────────────

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/giton"
HOSTS_FILE="${CONFIG_DIR}/hosts.json"

save_host() {
  local system="$1"
  local host="$2"
  mkdir -p "$CONFIG_DIR"
  if [[ -f "$HOSTS_FILE" ]]; then
    jq --arg s "$system" --arg h "$host" '.[$s] = $h' "$HOSTS_FILE" > "${HOSTS_FILE}.tmp"
    mv "${HOSTS_FILE}.tmp" "$HOSTS_FILE"
  else
    jq -n --arg s "$system" --arg h "$host" '{($s): $h}' > "$HOSTS_FILE"
  fi
}

# Look up or prompt for remote hostname
get_remote_host() {
  local system="$1"
  local host=""

  # Try reading from persisted hosts
  if [[ -f "$HOSTS_FILE" ]]; then
    host=$(jq -r --arg s "$system" '.[$s] // empty' "$HOSTS_FILE" 2>/dev/null || true)
  fi

  if [[ -n "$host" ]]; then
    log "Using saved host for ${system}: ${BOLD}${host}${RESET}"
  else
    # Flush any pending terminal responses before reading
    read -r -d '' -t 0.1 _discard </dev/tty 2>/dev/null || true
    echo -n "==> Enter hostname for ${system}: " >&2
    read -r host </dev/tty
    host=$(echo "$host" | tr -cd '[:alnum:]._-')
    if [[ -z "$host" ]]; then
      err "No hostname provided."
      exit 1
    fi
    save_host "$system" "$host"
  fi

  echo "$host"
}

# ─── Multi-step mode ─────────────────────────────────────────────────────────

if [[ -n "$CONFIG_FILE" ]]; then
  if [[ ! -f "$CONFIG_FILE" ]]; then
    err "Config file not found: $CONFIG_FILE"
    exit 1
  fi

  log "Multi-step mode: ${BOLD}${CONFIG_FILE}${RESET}  ${DIM}SHA=${SHA:0:12}${RESET}"

  # Resolve remote hosts upfront (process-compose subprocesses can't prompt).
  # Build system→hostname map for process-compose namespaces.
  CURRENT_SYSTEM=$(nix eval --raw --impure --expr builtins.currentSystem)
  HOST_MAP=$(jq -n --arg sys "$CURRENT_SYSTEM" --arg host "$(hostname)" '{($sys): $host}')
  REMOTE_SYSTEMS=$(jq -r '[.steps[].systems // [] | .[]] | unique[]' "$CONFIG_FILE")
  for sys in $REMOTE_SYSTEMS; do
    if [[ "$sys" != "$CURRENT_SYSTEM" ]]; then
      HOST=$(get_remote_host "$sys")
      HOST_MAP=$(echo "$HOST_MAP" | jq --arg sys "$sys" --arg host "$HOST" '. + {($sys): $host}')
      # Warm SSH connection (triggers password/key prompts while we have TTY)
      log "Warming SSH connection to ${BOLD}${HOST}${RESET} (${sys})..."
      ssh "$HOST" echo ok >/dev/null
    fi
  done

  # Generate process-compose config (JSON, which is valid YAML) from giton config
  LOG_DIR="/tmp/giton-${SHA:0:12}-logs"
  mkdir -p "$LOG_DIR"

  PC_FILE=$(mktemp /tmp/giton-pc-XXXXXX.json)
  cleanup_pc() { rm -f "$PC_FILE"; }
  trap cleanup_pc EXIT

  # Build process-compose config via jq.
  # Each step × system becomes a process; dependencies expand per-system.
  # Process-compose keys: just the step name when only one system,
  # "step (system)" when multiple systems for disambiguation.
  jq --arg sha "$SHA" --arg bin "$0" --arg wd "$PWD" --arg logdir "$LOG_DIR" --argjson hosts "$HOST_MAP" '
    .steps as $steps |

    # Build a lookup: for each step+system, what is the process key?
    # Used for both naming and dependency resolution.
    ( [ $steps | to_entries[] | .key as $step | .value as $cfg |
        ($cfg.systems // [null]) as $systems |
        $systems[] as $sys |
        { step: $step, sys: $sys,
          key: (if $sys == null then $step
                elif ($systems | length) == 1 then $step
                else $step + " (" + $sys + ")" end) }
      ] ) as $procs |

    [ $procs[] |
      .step as $step | .sys as $sys | .key as $name |
      ($steps[$step]) as $cfg |
      ( [$bin, "--sha", $sha]
        + (if $sys then ["-s", $sys] else [] end)
        + ["-n", $step, "--", $cfg.command] | join(" ")
      ) as $command |
      ($cfg.depends_on // []) as $deps |
      ( [ $deps[] as $dep |
          ( [ $procs[] | select(.step == $dep and .sys == $sys) ] | first // empty ) as $match |
          { key: $match.key, value: { condition: "process_completed_successfully" } }
        ] | from_entries | if length > 0 then . else null end
      ) as $depends |
      ( $logdir + "/" + ($name | gsub("[/ ()]"; "-") | gsub("--+"; "-") | gsub("-$"; "")) + ".log" ) as $logfile |
      { key: $name, value: (
        { command: $command, working_dir: $wd,
          log_location: $logfile,
          namespace: (if $sys then $sys + " (" + ($hosts[$sys] // "local") + ")" else null end),
          availability: { restart: "exit_on_failure" } }
        + if $depends then { depends_on: $depends } else {} end
        | del(.namespace | nulls)
      )}
    ] | from_entries |
    { version: "0.5",
      log_configuration: { flush_each_line: true },
      processes: . }
  ' "$CONFIG_FILE" > "$PC_FILE"

  PC_EXIT=0
  process-compose up --tui="$TUI" --no-server --config "$PC_FILE" || PC_EXIT=$?

  # Print summary report
  echo "" >&2
  if [[ $PC_EXIT -eq 0 ]]; then
    ok "All steps passed"
  else
    warn "One or more steps failed (exit ${PC_EXIT})"
    info "Logs: ${LOG_DIR}/"
    # In non-TUI mode, show log output for failed steps
    if [[ "$TUI" == false ]]; then
      for logfile in "$LOG_DIR"/*.log; do
        [[ -s "$logfile" ]] || continue
        grep -q "failed" "$logfile" || continue
        stepname=$(basename "$logfile" .log)
        echo "" >&2
        warn "${BOLD}${stepname}${RESET}:"
        jq -r '.message' "$logfile" >&2
      done
    fi
  fi
  exit $PC_EXIT
fi

# ─── Single-step mode ────────────────────────────────────────────────────────

if [[ ${#CMD[@]} -eq 0 ]]; then
  err "A command after -- is required (or use -f for multi-step mode)."
  usage
fi

# Default --name to first word of command
if [[ -z "$NAME" ]]; then
  NAME=$(basename "${CMD[0]}")
fi

# Build context: giton/<name> without --system, giton/<name>/<system> with
if [[ "$SYSTEM_EXPLICIT" == true ]]; then
  CONTEXT="giton/${NAME}/${SYSTEM}"
else
  CONTEXT="giton/${NAME}"
fi

# Get owner/repo from gh
REPO=$(gh repo view --json nameWithOwner --jq '.nameWithOwner')
if [[ -z "$REPO" ]]; then
  err "Could not determine GitHub repository. Is 'gh' authenticated?"
  exit 1
fi

log "${BOLD}${CONTEXT}${RESET}  ${DIM}${REPO}@${SHA:0:12}${RESET}"
info "${CMD[*]}"

# Post pending status
post_status() {
  local state="$1"
  local description="${2:-}"
  # GitHub status API enforces a 140-char limit on description
  description="${description:0:140}"
  gh api "repos/${REPO}/statuses/${SHA}" \
    -f state="$state" \
    -f context="$CONTEXT" \
    -f description="$description" \
    --silent
}

post_status "pending" "Running: ${CMD[*]}"

# Determine if we need remote execution
REMOTE=false
if [[ "$SYSTEM_EXPLICIT" == true ]]; then
  CURRENT_SYSTEM=$(nix eval --raw --impure --expr builtins.currentSystem)
  if [[ "$CURRENT_SYSTEM" != "$SYSTEM" ]]; then
    REMOTE=true
  fi
fi

run_cmd() {
  EXIT_CODE=0
  "$@" || EXIT_CODE=$?
}

CMD_START=$SECONDS

if [[ "$REMOTE" == true ]]; then
  # Remote execution
  HOST=$(get_remote_host "$SYSTEM")
  REMOTE_DIR="/tmp/giton-${SHA:0:12}-${NAME}"

  cleanup() {
    log "Cleaning up remote temp dir..."
    ssh "$HOST" "rm -rf '$REMOTE_DIR'" 2>/dev/null || true
  }
  trap cleanup EXIT

  # Ensure SSH ControlMaster socket directory exists
  SSH_CONTROL_PATH=$(ssh -G "$HOST" 2>/dev/null | awk '/^controlpath / {print $2}')
  if [[ -n "$SSH_CONTROL_PATH" ]]; then
    mkdir -p "$(dirname "$SSH_CONTROL_PATH")"
  fi

  log "Copying repo to ${BOLD}${HOST}${RESET}..."
  git archive --format=tar "$SHA" | ssh "$HOST" "mkdir -p '$REMOTE_DIR' && tar -C '$REMOTE_DIR' -x && chmod -R u+w '$REMOTE_DIR'"

  run_cmd ssh "$HOST" "cd '$REMOTE_DIR' && ${CMD[*]}"
else
  # Local execution: git archive to tmpdir
  TMPDIR=$(mktemp -d "/tmp/giton-${SHA:0:12}-XXXXXX")
  cleanup() {
    rm -rf "$TMPDIR"
  }
  trap cleanup EXIT

  log "Extracting repo..."
  git archive --format=tar "$SHA" | tar -C "$TMPDIR" -x
  chmod -R u+w "$TMPDIR"

  run_cmd bash -c "cd '$TMPDIR' && $(printf '%q ' "${CMD[@]}")"
fi

ELAPSED=$(fmt_time $(( SECONDS - CMD_START )))

if [[ $EXIT_CODE -eq 0 ]]; then
  ok "${BOLD}${CONTEXT}${RESET} passed in ${GREEN}${ELAPSED}${RESET}"
  post_status "success" "Passed in ${ELAPSED}: ${CMD[*]}"
else
  warn "${BOLD}${CONTEXT}${RESET} failed (exit ${EXIT_CODE}) in ${YELLOW}${ELAPSED}${RESET}"
  post_status "failure" "Failed (exit ${EXIT_CODE}) in ${ELAPSED}: ${CMD[*]}"
fi

exit $EXIT_CODE
