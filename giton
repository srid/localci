#!/usr/bin/env bash
set -euo pipefail

# Colors (disabled if not a terminal)
if [[ -t 2 ]]; then
  BOLD='\033[1m'    DIM='\033[2m'
  RED='\033[31m'    GREEN='\033[32m'
  YELLOW='\033[33m' CYAN='\033[36m'
  RESET='\033[0m'
else
  BOLD='' DIM='' RED='' GREEN='' YELLOW='' CYAN='' RESET=''
fi

log()   { echo -e "${CYAN}${BOLD}==>${RESET} $*" >&2; }
info()  { echo -e "    ${DIM}$*${RESET}" >&2; }
err()   { echo -e "${RED}${BOLD}Error:${RESET} $*" >&2; }
ok()    { echo -e "${GREEN}${BOLD}==>${RESET} $*" >&2; }
warn()  { echo -e "${YELLOW}${BOLD}==>${RESET} $*" >&2; }

usage() {
  echo "Usage: giton [--system <nix-system>] [--name <check-name>] -- <command...>"
  echo ""
  echo "Run a command on a specific Nix platform and post GitHub commit status."
  echo ""
  echo "Options:"
  echo "  -s, --system    Nix system string (if omitted, runs on current system)"
  echo "  -n, --name      Check name for GitHub status context (default: command name)"
  echo "  --              Separator before the command to run"
  echo ""
  echo "Status context: giton/<name> (no --system) or giton/<name>/<system> (with --system)"
  exit 1
}

# Parse arguments
SYSTEM=""
SYSTEM_EXPLICIT=false
NAME=""
CMD=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s|--system)
      SYSTEM="$2"
      SYSTEM_EXPLICIT=true
      shift 2
      ;;
    -n|--name)
      NAME="$2"
      shift 2
      ;;
    --)
      shift
      CMD=("$@")
      break
      ;;
    -h|--help)
      usage
      ;;
    *)
      echo "Error: Unknown option '$1'"
      usage
      ;;
  esac
done

if [[ ${#CMD[@]} -eq 0 ]]; then
  err "A command after -- is required."
  usage
fi

# Default --name to first word of command
if [[ -z "$NAME" ]]; then
  NAME=$(basename "${CMD[0]}")
fi

# Ensure we're in a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  err "Not inside a git repository."
  exit 1
fi

# Ensure working tree is clean
if ! git diff --quiet || ! git diff --cached --quiet || [[ -n "$(git ls-files --others --exclude-standard)" ]]; then
  err "Working tree is dirty. Commit or stash changes first."
  exit 1
fi

SHA=$(git rev-parse HEAD)

# Build context: giton/<name> without --system, giton/<name>/<system> with
if [[ "$SYSTEM_EXPLICIT" == true ]]; then
  CONTEXT="giton/${NAME}/${SYSTEM}"
else
  CONTEXT="giton/${NAME}"
fi

# Get owner/repo from gh
REPO=$(gh repo view --json nameWithOwner --jq '.nameWithOwner')
if [[ -z "$REPO" ]]; then
  err "Could not determine GitHub repository. Is 'gh' authenticated?"
  exit 1
fi

log "giton: ${BOLD}${CONTEXT}${RESET}"
info "repo:   ${REPO}"
info "commit: ${SHA:0:12}"
info "cmd:    ${CMD[*]}"

# Post pending status
post_status() {
  local state="$1"
  local description="${2:-}"
  gh api "repos/${REPO}/statuses/${SHA}" \
    -f state="$state" \
    -f context="$CONTEXT" \
    -f description="$description" \
    --silent
}

log "Posting ${YELLOW}pending${RESET} status..."
post_status "pending" "Running: ${CMD[*]}"

# Determine if we need remote execution
REMOTE=false
if [[ "$SYSTEM_EXPLICIT" == true ]]; then
  CURRENT_SYSTEM=$(nix eval --raw --impure --expr builtins.currentSystem)
  if [[ "$CURRENT_SYSTEM" != "$SYSTEM" ]]; then
    REMOTE=true
  fi
fi

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/giton"
HOSTS_FILE="${CONFIG_DIR}/hosts.json"

# Look up or prompt for remote hostname
get_remote_host() {
  local system="$1"
  local host=""

  # Try reading from persisted hosts
  if [[ -f "$HOSTS_FILE" ]]; then
    host=$(jq -r --arg s "$system" '.[$s] // empty' "$HOSTS_FILE" 2>/dev/null || true)
  fi

  if [[ -n "$host" ]]; then
    log "Using saved host for ${system}: ${BOLD}${host}${RESET}"
  else
    # Flush any pending terminal responses before reading
    read -r -d '' -t 0.1 _discard </dev/tty 2>/dev/null || true
    echo -n "==> Enter hostname for ${system}: " >&2
    read -r host </dev/tty
    host=$(echo "$host" | tr -cd '[:alnum:]._-')
    if [[ -z "$host" ]]; then
      err "No hostname provided."
      exit 1
    fi
    save_host "$system" "$host"
  fi

  echo "$host"
}

save_host() {
  local system="$1"
  local host="$2"
  mkdir -p "$CONFIG_DIR"
  if [[ -f "$HOSTS_FILE" ]]; then
    jq --arg s "$system" --arg h "$host" '.[$s] = $h' "$HOSTS_FILE" > "${HOSTS_FILE}.tmp"
    mv "${HOSTS_FILE}.tmp" "$HOSTS_FILE"
  else
    jq -n --arg s "$system" --arg h "$host" '{($s): $h}' > "$HOSTS_FILE"
  fi
}

if [[ "$REMOTE" == true ]]; then
  # Remote execution
  HOST=$(get_remote_host "$SYSTEM")
  REMOTE_DIR="/tmp/giton-${SHA:0:12}"

  cleanup() {
    log "Cleaning up remote temp dir..."
    ssh "$HOST" "rm -rf '$REMOTE_DIR'" 2>/dev/null || true
  }
  trap cleanup EXIT

  log "Copying repo to ${BOLD}${HOST}${RESET}:${REMOTE_DIR}..."
  git archive --format=tar HEAD | ssh "$HOST" "mkdir -p '$REMOTE_DIR' && tar -C '$REMOTE_DIR' -x"

  log "Running on ${BOLD}${HOST}${RESET}: ${CMD[*]}"
  EXIT_CODE=0
  ssh "$HOST" "cd '$REMOTE_DIR' && ${CMD[*]}" || EXIT_CODE=$?
else
  # Local execution: git archive to tmpdir
  TMPDIR=$(mktemp -d "/tmp/giton-${SHA:0:12}-XXXXXX")
  cleanup() {
    rm -rf "$TMPDIR"
  }
  trap cleanup EXIT

  log "Extracting repo to ${DIM}${TMPDIR}${RESET}..."
  git archive --format=tar HEAD | tar -C "$TMPDIR" -x

  log "Running: ${BOLD}${CMD[*]}${RESET}"
  EXIT_CODE=0
  (cd "$TMPDIR" && "${CMD[@]}") || EXIT_CODE=$?
fi

if [[ $EXIT_CODE -eq 0 ]]; then
  ok "Command succeeded. Posting ${GREEN}success${RESET} status."
  post_status "success" "Passed: ${CMD[*]}"
else
  warn "Command failed (exit code: ${EXIT_CODE}). Posting ${RED}failure${RESET} status."
  post_status "failure" "Failed (exit ${EXIT_CODE}): ${CMD[*]}"
fi

exit $EXIT_CODE
